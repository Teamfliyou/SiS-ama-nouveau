datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id       Int    @id @default(autoincrement())
  email    String @unique
  password String
}

model Class {
  id         Int       @id @default(autoincrement())
  name       String    @unique
  tuitionFee Float     @default(0)
  students   Student[]
  createdAt  DateTime  @default(now())
}

model Student {
  id             Int       @id @default(autoincrement())
  firstName      String
  lastName       String
  classId        Int?
  class          Class?    @relation(fields: [classId], references: [id])
  payments       Payment[]
  createdAt      DateTime  @default(now())
}

model Payment {
  id        Int      @id @default(autoincrement())
  amount    Float
  date      DateTime @default(now())
  studentId Int
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  method    String?  @default("Espèces")
}
